# ══════════════════════════════════════
# SparkInsight Analytics Platform
# Environment Configuration Template
# ══════════════════════════════════════
# Copy to .env and fill in your values

# Firebase Admin SDK
FIREBASE_CREDENTIALS_PATH=firebase_credentials.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# Spark Configuration
SPARK_APP_NAME=SparkInsight
SPARK_MASTER=local[*]
SPARK_DRIVER_MEMORY=4g
SPARK_EXECUTOR_MEMORY=4g
SPARK_DEFAULT_PARTITIONS=8

# Application
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
LOG_DIR=logs

# Dataset catalog path
DATASETS_CONFIG_PATH=backend/config/datasets.json

# Quality weights config (optional)
QUALITY_WEIGHTS_PATH=backend/config/quality_weights.json
